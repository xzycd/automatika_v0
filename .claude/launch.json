{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTTP (python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Static HTTP (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "-l", "3000", "."],
      "port": 3000
    }
  ]
}
